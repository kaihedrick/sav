  "dependencies": {
    "esbuild": "^0.24.0",
    "@aws-sdk/client-dynamodb": "^3.699.0",
    "@aws-sdk/client-secrets-manager": "^3.699.0",
    "@aws-sdk/lib-dynamodb": "^3.699.0",
    "jose": "^5.9.6",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "typescript": "^5.6.3"
  }
}
