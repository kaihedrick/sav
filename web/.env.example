VITE_API_URL=https://xxxx.execute-api.us-west-2.amazonaws.com
# Same Web client ID as SAM parameter GoogleClientId (GIS verifies aud)
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# Same email as SAM AdminEmail — SPA uses this to show admin nav (API enforces role in JWT)
VITE_ADMIN_EMAIL=savannah@example.com
