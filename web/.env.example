VITE_API_URL=https://xxxx.execute-api.us-west-2.amazonaws.com
# Same Web client ID as SAM parameter GoogleClientId (GIS verifies aud)
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# Same email as SAM AdminEmail — SPA uses this to show admin nav (API enforces role in JWT)
# Comma-separated if multiple admins: must match Lambda AdminEmail
VITE_ADMIN_EMAIL=rewindtothehd@gmail.com,your-other@gmail.com

# Vercel: Project Settings → Root Directory = web (or import this repo and set root to web).
# Add the same vars above under Settings → Environment Variables for Production (and Preview if desired).
# Google Cloud OAuth: Authorized JavaScript origins must include https://YOUR-PROJECT.vercel.app
# SAM: set AppBaseUrl to that same https origin so API CORS allows the browser.
